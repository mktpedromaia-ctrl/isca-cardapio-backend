PORT=3333

# === Provider de LLM (qualquer API compativel com OpenAI) ===
# No Railway, configure como variaveis de ambiente. Escolha UM bloco.

# Groq (GRATIS, rapido, com visao) - recomendado
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
LLM_API_KEY=sua_chave_groq

